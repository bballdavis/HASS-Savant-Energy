# Savant InfluxDB Configuration Example
# Copy this to .savant-local.env and fill in your actual values
# Do NOT commit .savant-local.env - it contains sensitive credentials

# Savant host IP/hostname
SAVANT_HOST=192.168.1.14

# SSH credentials for remote token retrieval
SAVANT_SSH_USER=RPM
SAVANT_SSH_PASSWORD=<your_ssh_password>

# InfluxDB endpoint
SAVANT_INFLUX_URL=http://192.168.1.14:8086

# Remote path to token file on Savant host
SAVANT_INFLUX_TOKEN_PATH=/data/RPM/GNUstep/Library/ApplicationSupport/RacePointMedia/statusfiles/InfluxDB2/.influxReadtoken

# (Optional) Pre-cached InfluxDB read token
# If not set, script will attempt to retrieve via SSH
SAVANT_INFLUX_TOKEN=<your_read_token>

# (Optional) Default organization ID or name
SAVANT_INFLUX_ORG=

# (Optional) Default bucket name
SAVANT_INFLUX_BUCKET=
